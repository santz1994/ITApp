}

/* Time Cards */
.time-card {
    border: none;
    border-radius: 15px;
    overflow: hidden;
    position: relative;
}

.time-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 5px;
}

.time-card-response::before {
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.time-card-resolution::before {
