}

/* Chart Cards */
.chart-card-wrapper {
    border: none;
    border-radius: 10px;
    overflow: hidden;
}

.chart-card-wrapper .card-header {
    background: linear-gradient(90deg, #f8f9fa 0%, #e9ecef 100%);
